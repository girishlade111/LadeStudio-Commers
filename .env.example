# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Google Sheets Configuration
# Get your Sheet ID from the Google Sheets URL
# Example: https://docs.google.com/spreadsheets/d/1ABC123XYZ.../edit
# The Sheet ID is: 1ABC123XYZ...
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx

# UPI Configuration for payments
UPI_ID=your_upi_id@upi

# WhatsApp Configuration (without + or 00 prefix)
WHATSAPP_NUMBER=919999999999

# Security - Rate limiting (optional, defaults are set in code)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30

# ===========================================
# PUBLIC ENVIRONMENT VARIABLES (NEXT_PUBLIC_)
# ===========================================
# These are exposed to the browser - only use for non-sensitive data

# Public WhatsApp number (for contact page)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public phone number (for contact page)
NEXT_PUBLIC_PHONE_NUMBER=+91 99999 99999

# UPI ID for checkout (public because it's shown in QR code)
NEXT_PUBLIC_UPI_ID=your_upi_id@upi
NEXT_PUBLIC_UPI_QR_URL=https://example.com/upi-qr.png
